<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter>

    <!-- Suppress warnings in generated/experimental test code -->
    <Match>
        <Package name="~be\.iffy\.fv\.test\..*"/>
    </Match>

    <!--
        EI_EXPOSE_REP / EI_EXPOSE_REP2: false positives for Vavr immutable collections.
        io.vavr.collection.List and io.vavr.collection.Map are structurally immutable;
        SpotBugs cannot verify this and flags their use as mutable representation exposure.
    -->
    <Match>
        <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2"/>
        <Or>
            <Class name="be.iffy.fv.ErrorMessage"/>
            <Class name="be.iffy.fv.Validation$Invalid"/>
            <Class name="be.iffy.fv.ValidationException"/>
        </Or>
    </Match>

</FindBugsFilter>
